# Auto-detect text files and normalize line endings
* text=auto

# Force LF for source files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Force CRLF for Windows-specific files
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.onnx binary
*.mp3 binary
*.wav binary
*.mp4 binary
*.png binary
*.ico binary
*.exe binary
