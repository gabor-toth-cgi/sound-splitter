{
  "name": "sound-splitter",
  "version": "1.0.0",
  "description": "A sound splitter GUI application using AI/ML to create mini tracks of a larger input media file (mp3, mp4, wav) by identifying speech and breaks in speech excluding background noise (non speech parts).",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "npx tsc && npx esbuild src/renderer/app.ts --bundle --outfile=dist/renderer/app.bundle.js --platform=browser --format=iife --target=es2022 --sourcemap",
    "start": "npm run build && cross-env NODE_OPTIONS=--use-system-ca NODE_TLS_REJECT_UNAUTHORIZED=0 npx electron .",
    "dev": "npm run build && cross-env NODE_OPTIONS=--use-system-ca NODE_TLS_REJECT_UNAUTHORIZED=0 npx electron .",
    "dist": "npm run build && npx electron-builder",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "audio",
    "speech",
    "splitter",
    "vad",
    "voice-activity-detection",
    "whisper",
    "electron",
    "silero",
    "onnx",
    "speech-recognition"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "electron-log": "^5.4.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "onnxruntime-node": "^1.14.0",
    "wavesurfer.js": "^7.12.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.soundsplitter.app",
    "productName": "Sound Splitter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*.html",
      "src/renderer/**/*.css",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "resources/models/silero_vad.onnx",
        "to": "models/silero_vad.onnx"
      }
    ]
  }
}
